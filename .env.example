# Ollama Configuration
# Forkers: Copy this to .env and configure your own values

# Ollama API endpoint (default local installation)
OLLAMA_HOST=http://localhost:11434

# Primary model for general tasks
OLLAMA_MODEL=mistral:latest

# Code generation model (smaller, faster for code tasks)
OLLAMA_CODE_MODEL=codellama:7b

# Request timeout in milliseconds
OLLAMA_TIMEOUT=120000

# Maximum tokens for responses
OLLAMA_MAX_TOKENS=4096

# Enable/disable streaming responses (true/false)
OLLAMA_STREAM=false
