# NextAura Hybrid Generator - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# OAuth Configuration
# ===========================================

# OAuth Provider (github, google, discord, etc.)
VITE_OAUTH_PROVIDER=github

# OAuth Client ID (required)
VITE_OAUTH_CLIENT_ID=your_client_id_here

# OAuth Client Secret (required)
VITE_OAUTH_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI (default: http://localhost:1420/callback)
VITE_OAUTH_REDIRECT_URI=http://localhost:1420/callback

# OAuth Scopes (space-separated)
VITE_OAUTH_SCOPE=read:user user:email

# OAuth Authorization URL (optional, auto-detected for common providers)
VITE_OAUTH_AUTH_URL=

# OAuth Token URL (optional, auto-detected for common providers)
VITE_OAUTH_TOKEN_URL=

# OAuth User Info URL (optional, auto-detected for common providers)
VITE_OAUTH_USER_INFO_URL=

# ===========================================
# Application Settings
# ===========================================

# Application Port (default: 1420)
VITE_APP_PORT=1420

# Application Name
VITE_APP_NAME=NextAura Hybrid Generator

# Debug Mode (true/false)
VITE_DEBUG_MODE=false

# ===========================================
# API Configuration
# ===========================================

# Backend API URL (if using external API)
VITE_API_URL=http://localhost:3000

# API Timeout (ms)
VITE_API_TIMEOUT=30000

# ===========================================
# Security
# ===========================================

# Session Secret (generate a random string)
VITE_SESSION_SECRET=your_session_secret_here

# CSRF Protection (true/false)
VITE_CSRF_PROTECTION=true

# ===========================================
# Logging
# ===========================================

# Log Level (debug, info, warn, error)
VITE_LOG_LEVEL=info

# Log to File (true/false)
VITE_LOG_TO_FILE=false

# Log File Path
VITE_LOG_FILE_PATH=./logs/app.log

# ===========================================
# Build Configuration
# ===========================================

# Source Maps (true/false)
VITE_SOURCE_MAPS=true

# Minification (true/false)
VITE_MINIFICATION=true

# ===========================================
# Feature Flags
# ===========================================

# Enable PKCE (true/false)
VITE_ENABLE_PKCE=true

# Enable Token Refresh (true/false)
VITE_ENABLE_TOKEN_REFRESH=true

# Enable Offline Access (true/false)
VITE_ENABLE_OFFLINE_ACCESS=false
